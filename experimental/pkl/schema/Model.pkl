/// A machine learning model offered by a provider.
module Model

import "Provider.pkl"

/// Model identifier used by the AI SDK for lookups.
id: String(!isEmpty)

/// Human-readable metadata (display name, dates, family).
metadata: Metadata

/// Feature flags describing what the model supports.
capabilities: Listing<Capability>

/// Supported input and output modalities.
modalities: Modalities

/// Context window and token limits.
limit: Limit

/// Per-model overrides for provider-level settings.
provider_override: ProviderOverride?

/// Lifecycle status (alpha, beta, deprecated). Null means generally available.
status: Status?

/// Human-readable metadata about a model.
class Metadata {
  /// Display name of the model.
  name: String(!isEmpty)

  /// First public release date (YYYY-MM or YYYY-MM-DD).
  release_date: String(matches(Regex(#"^\d{4}-\d{2}(-\d{2})?$"#)))

  /// Most recent update date (YYYY-MM or YYYY-MM-DD).
  last_updated: String(matches(Regex(#"^\d{4}-\d{2}(-\d{2})?$"#)))

  /// Knowledge cutoff date (YYYY-MM or YYYY-MM-DD).
  knowledge: String(matches(Regex(#"^\d{4}-\d{2}(-\d{2})?$"#)))?

  /// Model family (e.g. "gpt", "claude", "gemini").
  family: String?
}

typealias Modality = "text" | "audio" | "image" | "video" | "pdf"

class Modalities {
  /// Supported input modalities.
  input: Listing<Modality>

  /// Supported output modalities.
  output: Listing<Modality>
}

/// Model capability flags:
/// - "attachment": supports file attachments
/// - "reasoning": supports reasoning / chain-of-thought
/// - "tool_call": supports tool calling
/// - "temperature": supports temperature control
/// - "structured_output": supports a dedicated structured output feature
/// - "open_weights": model's trained weights are publicly available
typealias Capability =
  "attachment"
  | "reasoning"
  | "tool_call"
  | "temperature"
  | "structured_output"
  | "open_weights"

/// Per-model overrides for provider-level settings.
class ProviderOverride {
  client_type: Provider.ClientType?

  base_url: String?
}

/// Context window and token limits for a model.
class Limit {
  /// Maximum context window in tokens.
  context: Int(isPositive)

  /// Maximum input tokens.
  input: Int(isPositive)?

  /// Maximum output tokens.
  output: Int(isPositive)
}

/// Lifecycle status of a model.
typealias Status = "alpha" | "beta" | "deprecated"

/// References a specific model by provider ID and model name.
class Identifier {
  /// Provider ID (must match a key in the provider catalog).
  provider: String(!isEmpty)

  /// Model name (must match a key in the provider's models mapping).
  name: String(!isEmpty)
}

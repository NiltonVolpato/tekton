/// TODO: Auto-generate this file from models.dev JSON Schema.
/// Currently requires a manual patch after generation:
///   Add `client_type: "Anthropic"|"OpenAI"|"OpenAICompatible"|"Gemini"` field after `npm`
module providerSchema

class Provider {
  id: String

  env: Listing<String>(!isEmpty)

  npm: String(!isEmpty)

  client_type: "Anthropic"|"OpenAI"|"OpenAICompatible"|"Gemini"

  api: String?

  name: String(!isEmpty)

  doc: String(!isEmpty)

  models: Mapping<String, Models>
}

class Models {
  id: String

  name: String(!isEmpty)

  family: String?

  attachment: Boolean

  reasoning: Boolean

  tool_call: Boolean

  interleaved: (Boolean(this == true)|InterleavedAlternate1)?

  structured_output: Boolean?

  temperature: Boolean?

  knowledge: String(matches(Regex(#"^\d{4}-\d{2}(-\d{2})?$"#)))?

  release_date: String(matches(Regex(#"^\d{4}-\d{2}(-\d{2})?$"#)))

  last_updated: String(matches(Regex(#"^\d{4}-\d{2}(-\d{2})?$"#)))

  modalities: Modalities

  open_weights: Boolean

  cost: Cost?

  limit: Limit

  status: ModelStatus?

  provider: ModelsProvider?
}

typealias Modality = "text"|"audio"|"image"|"video"|"pdf"

typealias ModelStatus = "alpha"|"beta"|"deprecated"

class InterleavedAlternate1 {
  field: "reasoning_content"|"reasoning_details"
}

class Modalities {
  input: Listing<Modality>

  output: Listing<Modality>
}

class Cost {
  input: Number(isPositive)

  output: Number(isPositive)

  reasoning: Number(isPositive)?

  cache_read: Number(isPositive)?

  cache_write: Number(isPositive)?

  input_audio: Number(isPositive)?

  output_audio: Number(isPositive)?

  context_over_200k: ContextOver200k?
}

class ContextOver200k {
  input: Number(isPositive)

  output: Number(isPositive)

  reasoning: Number(isPositive)?

  cache_read: Number(isPositive)?

  cache_write: Number(isPositive)?

  input_audio: Number(isPositive)?

  output_audio: Number(isPositive)?
}

class Limit {
  context: Number(isPositive)

  input: Number(isPositive)?

  output: Number(isPositive)
}

class ModelsProvider {
  npm: String?

  api: String?
}

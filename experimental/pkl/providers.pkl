/// User's provider override layer.
///
/// Amends the generated catalog to add custom or local providers.
/// Place this file in the user config directory (e.g. `~/.tekton/models_dev/`).
amends "models_dev/providersModelsDev.pkl"

/// Add custom providers here or in a project-level override:
///   providers {
///     ["my-local"] {
///       id = "my-local"
///       metadata { name = "My Local LLM"; doc = "https://..." }
///       client_type = "OpenAICompatible"
///       env {}
///       base_url = "http://localhost:8080/v1"
///       model {}
///     }
///   }

// Inherit all catalog providers. Add custom entries above.
providers {}

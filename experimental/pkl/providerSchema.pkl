/// Core type definitions for the provider/model catalog.
///
/// Defines [Provider], [Model], and supporting types (capabilities, modalities, limits).
/// All other Pkl files in this project reference these types.
module providerSchema

class ProviderMetadata {
  /// Display name of the provider.
  name: String(!isEmpty)
  /// Link to the provider's documentation.
  doc: String(!isEmpty)
}

typealias ClientType = "Anthropic" | "OpenAI" | "OpenAICompatible" | "Gemini"

class Provider {
  /// Unique provider identifier (e.g. "anthropic", "openai").
  id: String(!isEmpty)
  metadata: ProviderMetadata

  /// Determines which client to use for API calls.
  client_type: ClientType
  /// Environment variables used for auth (e.g. "ANTHROPIC_API_KEY").
  /// May be empty for local providers that use credentials directly.
  env: Listing<String>
  /// Base URL for the API endpoint. Required for OpenAI-compatible providers.
  base_url: String?
  /// Models this provider supports, keyed by model ID.
  model: Mapping<String, Model>
}

// ---

/// Human-readable metadata about a model.
class ModelMetadata {
  /// Display name of the model.
  name: String(!isEmpty)
  /// First public release date (YYYY-MM or YYYY-MM-DD).
  release_date: String(matches(Regex(#"^\d{4}-\d{2}(-\d{2})?$"#)))
  /// Most recent update date (YYYY-MM or YYYY-MM-DD).
  last_updated: String(matches(Regex(#"^\d{4}-\d{2}(-\d{2})?$"#)))

  /// Knowledge cutoff date (YYYY-MM or YYYY-MM-DD).
  knowledge: String(matches(Regex(#"^\d{4}-\d{2}(-\d{2})?$"#)))?
  /// Model family (e.g. "gpt", "claude", "gemini").
  family: String?
}

typealias Modality = "text" | "audio" | "image" | "video" | "pdf"

class Modalities {
  /// Supported input modalities.
  input: Listing<Modality>
  /// Supported output modalities.
  output: Listing<Modality>
}

/// Model capability flags:
/// - "attachment": supports file attachments
/// - "reasoning": supports reasoning / chain-of-thought
/// - "tool_call": supports tool calling
/// - "temperature": supports temperature control
/// - "structured_output": supports a dedicated structured output feature
/// - "open_weights": model's trained weights are publicly available
typealias ModelCapability =
  "attachment"
  | "reasoning"
  | "tool_call"
  | "temperature"
  | "structured_output"
  | "open_weights"

/// Per-model overrides for provider-level settings.
class ProviderOverride {
  client_type: ClientType?
  base_url: String?
}

/// Context window and token limits for a model.
class Limit {
  /// Maximum context window in tokens.
  context: Int(isPositive)
  /// Maximum input tokens.
  input: Int(isPositive)?
  /// Maximum output tokens.
  output: Int(isPositive)
}

/// Lifecycle status of a model.
typealias ModelStatus = "alpha" | "beta" | "deprecated"

class Model {
  /// Model identifier used by the AI SDK for lookups.
  id: String(!isEmpty)
  metadata: ModelMetadata
  capabilities: Listing<ModelCapability>
  modalities: Modalities
  limit: Limit
  /// Per-model overrides for provider-level settings.
  provider_override: ProviderOverride?
  status: ModelStatus?
}

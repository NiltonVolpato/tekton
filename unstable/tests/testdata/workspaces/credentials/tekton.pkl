amends ".../config.pkl"

default_agent = "test"

credentials {
  ["anthropic"] = new {
    api_key = "sk-ant-test-key"
  }
  ["custom"] = new {
    api_key = "custom-key"
  }
}

agents {
  ["test"] = new {
    model = new { provider = "anthropic"; name = "claude-sonnet-4-6" }
    system_prompt = "Test."
  }
}

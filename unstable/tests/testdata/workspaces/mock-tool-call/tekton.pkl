amends ".../config.pkl"

default_agent = "tool-call-agent"

credentials {
  ["mock"] = new {
    api_key = "fake-key"
  }
}

provider_catalog = (super.provider_catalog) {
  ["mock"] = new {
    id = "mock"
    metadata { name = "Mock Server"; doc = "https://example.com" }
    client_type = "OpenAICompatible"
    base_url = "http://localhost:8100/v1/tool-call"
    env {}
    models {
      ["openai"] = new {
        id = "openai"
        metadata { name = "OpenAI Mock"; release_date = "2025-01"; last_updated = "2025-01" }
        capabilities {}
        modalities { input { "text" }; output { "text" } }
        limit { context = 128000; output = 4096 }
      }
    }
  }
}

agents {
  ["tool-call-agent"] = new {
    model = new { provider = "mock"; name = "openai" }
    system_prompt = "You are a test agent with terminal access."
  }
}
